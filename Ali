<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NEURAL — AI Interface</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #050508;
    --surface: #0d0d14;
    --surface2: #13131e;
    --border: rgba(255,255,255,0.07);
    --accent: #7cffd4;
    --accent2: #ff6b6b;
    --accent3: #a78bfa;
    --text: #e8e8f0;
    --text-dim: #6b6b80;
    --text-dimmer: #3a3a4a;
    --glow: rgba(124,255,212,0.15);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Background grid */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(124,255,212,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(124,255,212,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  /* Ambient glow blobs */
  .blob {
    position: fixed;
    border-radius: 50%;
    filter: blur(120px);
    pointer-events: none;
    z-index: 0;
  }
  .blob-1 {
    width: 500px; height: 500px;
    background: rgba(124,255,212,0.04);
    top: -100px; left: -100px;
  }
  .blob-2 {
    width: 400px; height: 400px;
    background: rgba(167,139,250,0.05);
    bottom: 100px; right: -50px;
  }

  header {
    position: relative;
    z-index: 10;
    padding: 24px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(10px);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .logo-icon {
    width: 32px; height: 32px;
    position: relative;
  }

  .logo-icon svg { width: 100%; height: 100%; }

  .logo-text {
    font-size: 18px;
    font-weight: 800;
    letter-spacing: 0.15em;
    color: var(--accent);
  }

  .status-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: rgba(124,255,212,0.06);
    border: 1px solid rgba(124,255,212,0.2);
    border-radius: 100px;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.05em;
  }

  .status-dot {
    width: 6px; height: 6px;
    background: var(--accent);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.8); }
  }

  .main {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    height: calc(100vh - 73px);
    background: var(--border);
  }

  .panel {
    background: var(--bg);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .panel-header {
    padding: 20px 28px 16px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
  }

  .panel-title {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .panel-num {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--text-dimmer);
    letter-spacing: 0.1em;
  }

  .panel-label {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .panel-badge {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    padding: 3px 8px;
    border-radius: 4px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .badge-ask { background: rgba(124,255,212,0.08); color: var(--accent); border: 1px solid rgba(124,255,212,0.2); }
  .badge-vision { background: rgba(167,139,250,0.08); color: var(--accent3); border: 1px solid rgba(167,139,250,0.2); }

  /* ── Q&A PANEL ── */
  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 24px 28px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    scroll-behavior: smooth;
  }

  .chat-messages::-webkit-scrollbar { width: 4px; }
  .chat-messages::-webkit-scrollbar-track { background: transparent; }
  .chat-messages::-webkit-scrollbar-thumb { background: var(--text-dimmer); border-radius: 2px; }

  .msg {
    display: flex;
    gap: 12px;
    animation: msgIn 0.3s ease forwards;
  }

  @keyframes msgIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .msg.user { flex-direction: row-reverse; }

  .msg-avatar {
    width: 28px; height: 28px;
    border-radius: 6px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
  }

  .msg.ai .msg-avatar { background: rgba(124,255,212,0.1); color: var(--accent); border: 1px solid rgba(124,255,212,0.2); }
  .msg.user .msg-avatar { background: rgba(167,139,250,0.1); color: var(--accent3); border: 1px solid rgba(167,139,250,0.2); }

  .msg-bubble {
    max-width: 75%;
    padding: 12px 16px;
    border-radius: 12px;
    font-size: 14px;
    line-height: 1.6;
    font-family: 'Syne', sans-serif;
  }

  .msg.ai .msg-bubble {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    border-top-left-radius: 2px;
  }

  .msg.user .msg-bubble {
    background: rgba(124,255,212,0.07);
    border: 1px solid rgba(124,255,212,0.15);
    color: var(--text);
    border-top-right-radius: 2px;
  }

  .typing-indicator {
    display: flex;
    gap: 4px;
    align-items: center;
    padding: 4px 0;
  }

  .typing-dot {
    width: 5px; height: 5px;
    background: var(--accent);
    border-radius: 50%;
    animation: typingBounce 1.2s ease-in-out infinite;
  }
  .typing-dot:nth-child(2) { animation-delay: 0.2s; }
  .typing-dot:nth-child(3) { animation-delay: 0.4s; }

  @keyframes typingBounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30% { transform: translateY(-5px); opacity: 1; }
  }

  .chat-input-area {
    padding: 16px 28px 20px;
    border-top: 1px solid var(--border);
    flex-shrink: 0;
  }

  .input-row {
    display: flex;
    gap: 10px;
    align-items: flex-end;
  }

  .chat-input {
    flex: 1;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 16px;
    color: var(--text);
    font-family: 'Syne', sans-serif;
    font-size: 14px;
    resize: none;
    outline: none;
    min-height: 44px;
    max-height: 120px;
    transition: border-color 0.2s;
    line-height: 1.5;
  }

  .chat-input::placeholder { color: var(--text-dimmer); }
  .chat-input:focus { border-color: rgba(124,255,212,0.3); }

  .send-btn {
    width: 44px; height: 44px;
    background: var(--accent);
    border: none;
    border-radius: 10px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all 0.2s;
    color: var(--bg);
  }

  .send-btn:hover { background: #a0ffe0; transform: scale(1.05); }
  .send-btn:active { transform: scale(0.97); }
  .send-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

  /* ── VISION PANEL ── */
  .vision-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .screen-area {
    flex: 1;
    padding: 20px 28px 16px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    overflow: hidden;
  }

  .screen-preview {
    flex: 1;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 0;
  }

  .screen-preview video,
  .screen-preview canvas {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 11px;
    display: none;
  }

  .screen-preview video.active,
  .screen-preview canvas.active {
    display: block;
  }

  .preview-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 40px;
    text-align: center;
  }

  .preview-placeholder.hidden { display: none; }

  .placeholder-icon {
    width: 64px; height: 64px;
    background: rgba(167,139,250,0.06);
    border: 1px solid rgba(167,139,250,0.15);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent3);
  }

  .placeholder-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--text-dim);
    letter-spacing: 0.05em;
  }

  .placeholder-sub {
    font-size: 12px;
    color: var(--text-dimmer);
    font-family: 'Space Mono', monospace;
    line-height: 1.7;
  }

  .share-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background: rgba(167,139,250,0.08);
    border: 1px solid rgba(167,139,250,0.25);
    border-radius: 8px;
    color: var(--accent3);
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.04em;
  }

  .share-btn:hover { background: rgba(167,139,250,0.14); transform: translateY(-1px); }
  .share-btn:active { transform: translateY(0); }

  .screen-controls {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-shrink: 0;
  }

  .ctrl-btn {
    flex: 1;
    padding: 10px 16px;
    border-radius: 8px;
    font-family: 'Syne', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    cursor: pointer;
    border: 1px solid;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  .ctrl-stop {
    background: rgba(255,107,107,0.06);
    border-color: rgba(255,107,107,0.2);
    color: var(--accent2);
  }
  .ctrl-stop:hover { background: rgba(255,107,107,0.12); }

  .ctrl-analyze {
    background: rgba(167,139,250,0.08);
    border-color: rgba(167,139,250,0.25);
    color: var(--accent3);
  }
  .ctrl-analyze:hover { background: rgba(167,139,250,0.14); }

  .ctrl-btn:disabled { opacity: 0.35; cursor: not-allowed; }

  .vision-output {
    padding: 0 28px 20px;
    flex-shrink: 0;
    max-height: 160px;
    overflow-y: auto;
  }

  .vision-output::-webkit-scrollbar { width: 3px; }
  .vision-output::-webkit-scrollbar-thumb { background: var(--text-dimmer); }

  .vision-result {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px 16px;
    font-size: 13px;
    line-height: 1.7;
    color: var(--text-dim);
    font-family: 'Space Mono', monospace;
    min-height: 60px;
    position: relative;
    overflow: hidden;
  }

  .vision-result::before {
    content: 'VISION OUTPUT';
    display: block;
    font-size: 9px;
    color: var(--accent3);
    letter-spacing: 0.15em;
    margin-bottom: 8px;
    opacity: 0.7;
  }

  .vision-result.loading::after {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(167,139,250,0.06), transparent);
    animation: shimmer 1.5s ease-in-out infinite;
  }

  @keyframes shimmer {
    to { left: 160%; }
  }

  /* Divider line between panels */
  .divider { background: var(--border); width: 1px; }

  /* Empty state for chat */
  .empty-chat {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex: 1;
    gap: 12px;
    padding: 40px;
    text-align: center;
    opacity: 0.6;
  }

  .empty-chat-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--text-dim);
    letter-spacing: 0.08em;
  }

  .empty-chat-sub {
    font-size: 11px;
    color: var(--text-dimmer);
    font-family: 'Space Mono', monospace;
    line-height: 1.8;
  }

  .corner-tag {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    color: var(--text-dimmer);
    letter-spacing: 0.1em;
  }

  @media (max-width: 768px) {
    .main { grid-template-columns: 1fr; height: auto; }
    .panel { height: 50vh; }
    header { padding: 16px 20px; }
  }
</style>
</head>
<body>

<div class="blob blob-1"></div>
<div class="blob blob-2"></div>

<header>
  <div class="logo">
    <div class="logo-icon">
      <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="16" cy="16" r="15" stroke="rgba(124,255,212,0.3)" stroke-width="1"/>
        <circle cx="16" cy="16" r="6" fill="rgba(124,255,212,0.15)" stroke="rgba(124,255,212,0.6)" stroke-width="1"/>
        <line x1="16" y1="1" x2="16" y2="10" stroke="rgba(124,255,212,0.4)" stroke-width="1"/>
        <line x1="16" y1="22" x2="16" y2="31" stroke="rgba(124,255,212,0.4)" stroke-width="1"/>
        <line x1="1" y1="16" x2="10" y2="16" stroke="rgba(124,255,212,0.4)" stroke-width="1"/>
        <line x1="22" y1="16" x2="31" y2="16" stroke="rgba(124,255,212,0.4)" stroke-width="1"/>
      </svg>
    </div>
    <span class="logo-text">NEURAL</span>
  </div>
  <div class="status-pill">
    <span class="status-dot"></span>
    SYSTEMS ONLINE
  </div>
  <span class="corner-tag">v2.4.1</span>
</header>

<div class="main">

  <!-- Q&A PANEL -->
  <div class="panel" id="qa-panel">
    <div class="panel-header">
      <div class="panel-title">
        <span class="panel-num">01 /</span>
        <span class="panel-label">Ask Anything</span>
      </div>
      <span class="panel-badge badge-ask">Q&A</span>
    </div>

    <div class="chat-messages" id="chat-messages">
      <div class="empty-chat" id="empty-state">
        <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
          <rect x="4" y="8" width="32" height="22" rx="4" stroke="rgba(124,255,212,0.3)" stroke-width="1.5"/>
          <line x1="12" y1="16" x2="28" y2="16" stroke="rgba(124,255,212,0.2)" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="12" y1="21" x2="22" y2="21" stroke="rgba(124,255,212,0.2)" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M14 30 L20 36 L26 30" stroke="rgba(124,255,212,0.2)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="empty-chat-title">Start a conversation</span>
        <span class="empty-chat-sub">Ask me anything — I'm powered<br>by Claude AI</span>
      </div>
    </div>

    <div class="chat-input-area">
      <div class="input-row">
        <textarea
          class="chat-input"
          id="chat-input"
          placeholder="Ask me anything..."
          rows="1"
        ></textarea>
        <button class="send-btn" id="send-btn" aria-label="Send">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
            <path d="M2 8L14 2L10 8L14 14L2 8Z"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- VISION PANEL -->
  <div class="panel" id="vision-panel">
    <div class="panel-header">
      <div class="panel-title">
        <span class="panel-num">02 /</span>
        <span class="panel-label">Screen Vision</span>
      </div>
      <span class="panel-badge badge-vision">VISION</span>
    </div>

    <div class="vision-body">
      <div class="screen-area">
        <div class="screen-preview" id="screen-preview">
          <video id="screen-video" autoplay muted playsinline></video>
          <canvas id="screen-canvas"></canvas>

          <div class="preview-placeholder" id="preview-placeholder">
            <div class="placeholder-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                <rect x="2" y="4" width="24" height="16" rx="3" stroke="currentColor" stroke-width="1.5"/>
                <line x1="10" y1="20" x2="18" y2="20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <line x1="14" y1="20" x2="14" y2="24" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="14" cy="12" r="4" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="14" cy="12" r="1.5" fill="currentColor"/>
              </svg>
            </div>
            <span class="placeholder-title">Share Your Screen</span>
            <span class="placeholder-sub">Click below to start screen sharing.<br>AI will analyze what it sees.</span>
            <button class="share-btn" id="start-share-btn">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor">
                <path d="M7 1L11 5H8V10H6V5H3L7 1Z"/>
                <path d="M2 11H12V13H2V11Z"/>
              </svg>
              Share Screen
            </button>
          </div>
        </div>

        <div class="screen-controls" id="screen-controls" style="display:none">
          <button class="ctrl-btn ctrl-stop" id="stop-btn">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor">
              <rect width="10" height="10" rx="1"/>
            </svg>
            Stop Sharing
          </button>
          <button class="ctrl-btn ctrl-analyze" id="analyze-btn">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor">
              <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.2" fill="none"/>
              <circle cx="6" cy="6" r="2" fill="currentColor"/>
              <line x1="6" y1="1" x2="6" y2="3" stroke="currentColor" stroke-width="1.2"/>
              <line x1="6" y1="9" x2="6" y2="11" stroke="currentColor" stroke-width="1.2"/>
              <line x1="1" y1="6" x2="3" y2="6" stroke="currentColor" stroke-width="1.2"/>
              <line x1="9" y1="6" x2="11" y2="6" stroke="currentColor" stroke-width="1.2"/>
            </svg>
            Analyze Frame
          </button>
        </div>
      </div>

      <div class="vision-output">
        <div class="vision-result" id="vision-result">
          Waiting for screen share to begin...
        </div>
      </div>
    </div>
  </div>

</div>

<script>
// ── CHAT ──────────────────────────────────────────────────────────────
const chatMessages = document.getElementById('chat-messages');
const chatInput = document.getElementById('chat-input');
const sendBtn = document.getElementById('send-btn');
const emptyState = document.getElementById('empty-state');

let conversationHistory = [];

function appendMessage(role, text) {
  if (emptyState) emptyState.remove();

  const msg = document.createElement('div');
  msg.className = `msg ${role}`;

  const avatar = document.createElement('div');
  avatar.className = 'msg-avatar';
  avatar.textContent = role === 'ai' ? 'AI' : 'U';

  const bubble = document.createElement('div');
  bubble.className = 'msg-bubble';
  bubble.textContent = text;

  msg.appendChild(avatar);
  msg.appendChild(bubble);
  chatMessages.appendChild(msg);
  chatMessages.scrollTop = chatMessages.scrollHeight;
  return bubble;
}

function showTyping() {
  const msg = document.createElement('div');
  msg.className = 'msg ai';
  msg.id = 'typing-msg';

  const avatar = document.createElement('div');
  avatar.className = 'msg-avatar';
  avatar.textContent = 'AI';

  const bubble = document.createElement('div');
  bubble.className = 'msg-bubble';
  bubble.innerHTML = `<div class="typing-indicator">
    <div class="typing-dot"></div>
    <div class="typing-dot"></div>
    <div class="typing-dot"></div>
  </div>`;

  msg.appendChild(avatar);
  msg.appendChild(bubble);
  chatMessages.appendChild(msg);
  chatMessages.scrollTop = chatMessages.scrollHeight;
}

function removeTyping() {
  const t = document.getElementById('typing-msg');
  if (t) t.remove();
}

async function sendMessage() {
  const text = chatInput.value.trim();
  if (!text) return;

  chatInput.value = '';
  chatInput.style.height = 'auto';
  sendBtn.disabled = true;

  appendMessage('user', text);
  conversationHistor
